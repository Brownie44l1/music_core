# music_core — environment variables
# Copy this file to .env and fill in your values.
# Never commit .env to git.

# Postgres
POSTGRES_PASSWORD=changeme

# Backend → Postgres
DATABASE_URL=postgresql://postgres:changeme@postgres:5432/music_core

# Backend → Redis
REDIS_URL=redis://redis:6379/0

# Backend → ML engine
ML_ENGINE_URL=http://ml:8001

# App environment (development | production)
APP_ENV=development
