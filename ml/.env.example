# ─── ML Engine ────────────────────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.

# Application
APP_ENV=development                  # development | production
APP_PORT=8001                        # ML engine runs on 8001, backend on 8000

# PostgreSQL
DATABASE_URL=postgresql://postgres:password@localhost:5432/music_core

# Redis
REDIS_URL=redis://localhost:6379/0

# Deezer API (no key needed — public API)
DEEZER_BASE_URL=https://api.deezer.com

# Model settings
MODEL_VERSION=v1
COLD_START_THRESHOLD=5               # interactions needed before personalisation kicks in
RECOMMENDATION_COUNT=10              # number of songs to return per request
CACHE_TTL_SECONDS=3600               # 1 hour cache expiry
